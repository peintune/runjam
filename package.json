{
  "name": "runjam",
  "version": "0.1.0",
  "type": "module",
  "description": "RunJam — A unified desktop manager for AI coding agents. Run Claude Code, Codex CLI, and Gemini CLI in one place.",
  "license": "MIT",
  "homepage": "https://github.com/nicepkg/runjam",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/runjam.git"
  },
  "bugs": {
    "url": "https://github.com/nicepkg/runjam/issues"
  },
  "keywords": [
    "ai-agent",
    "ai-coding",
    "claude-code",
    "codex-cli",
    "gemini-cli",
    "tauri",
    "desktop-app",
    "developer-tools",
    "llm",
    "coding-assistant",
    "agent-manager",
    "local-first",
    "rust",
    "vue",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "dev:landing": "BUILD_TARGET=landing vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:landing": "BUILD_TARGET=landing vite build && cp dist-landing/landing.html dist-landing/index.html",
    "preview": "vite preview",
    "preview:landing": "BUILD_TARGET=landing vite preview --outDir dist-landing",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.577.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
